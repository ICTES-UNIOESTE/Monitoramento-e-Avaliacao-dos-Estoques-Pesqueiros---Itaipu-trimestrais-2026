)

padroniza_estoque <- function(x){
  original <- as.character(x)
  original <- trimws(original)
  chave <- limpa_chave(original)
  saida <- original
  ind <- chave %in% names(dicionario_estoque)
  saida[ind] <- dicionario_estoque[chave[ind]]
  saida
}

