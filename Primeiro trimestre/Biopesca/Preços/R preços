################################################################################
# FunĂ§ĂŁo para gerar tabelas de preĂ§o ####
# MantĂ©m a mesma lĂłgica do cĂłdigo anterior:
# 1) mĂ©dia e desvio-padrĂŁo geral por estoque;
# 2) mĂ©dia e desvio-padrĂŁo por zona e estoque;
# 3) completa as combinaĂ§Ăµes ausentes entre estoque e zona.

gera_tabelas_preco <- function(dados, coluna_preco, arquivo_geral, arquivo_zona){
  
  Preco <- dados
  Preco$Preco_valor <- suppressWarnings(as.numeric(Preco[[coluna_preco]]))
  
  Preco <- Preco[Preco$Preco_valor > 0 &
                   !is.na(Preco$Preco_valor) &
                   !is.na(Preco$Estoque) &
                   trimws(Preco$Estoque) != "", ]
  
  Preco <- Preco[, c("Zona", "Estoque", "Preco_valor")]
  colnames(Preco) <- c("Zona", "EspĂ©cie", "PreĂ§o")
  
  Preco$Zona <- factor(Preco$Zona,
                       levels = c("Fluvial", "TransiĂ§ĂŁo", "Lacustre", "Montante"))
  
  # Geral
  overall_summary <- aggregate(PreĂ§o ~ EspĂ©cie,
                               data = Preco,
                               FUN = function(x) c(mean = mean(x, na.rm = TRUE),
                                                   sd = sd(x, na.rm = TRUE)))
  
  overall_summary$Zona <- "Geral"
  overall_summary <- as.data.frame(overall_summary)
  colnames(overall_summary) <- c("EspĂ©cies", "PreĂ§o", "Zona")
  
  overall_summary$PreĂ§o_mean <- overall_summary$PreĂ§o[, 1]
  overall_summary$PreĂ§o_sd <- overall_summary$PreĂ§o[, 2]
  overall_summary <- overall_summary[, -2]
  
  overall_summary <- overall_summary %>%
    arrange(EspĂ©cies)
  
  write.xlsx(overall_summary,
             file = arquivo_geral,
             rowNames = FALSE)
  
  # Por zona
  zona_summary <- aggregate(PreĂ§o ~ EspĂ©cie + Zona,
                            data = Preco,
                            FUN = function(x) c(mean = mean(x, na.rm = TRUE),
                                                sd = sd(x, na.rm = TRUE)))
  
  zona_summary <- zona_summary %>%
    arrange(EspĂ©cie)
  
  complete_set <- expand.grid(EspĂ©cie = unique(zona_summary$EspĂ©cie),
                              Zona = c("Fluvial", "TransiĂ§ĂŁo", "Lacustre", "Montante"))
  
  zona_summary_complete <- merge(zona_summary,
                                 complete_set,
                                 by = c("EspĂ©cie", "Zona"),
                                 all = TRUE)
  
  zona_summary_complete$Zona <- factor(zona_summary_complete$Zona,
                                       levels = c("Fluvial", "TransiĂ§ĂŁo", "Lacustre", "Montante"))
  
  zona_summary_complete <- zona_summary_complete %>%
    arrange(EspĂ©cie, Zona)
  
  colnames(zona_summary_complete) <- c("EspĂ©cies", "Zona", "PreĂ§o")
  
  zona_summary_complete$PreĂ§o_mean <- zona_summary_complete$PreĂ§o[, 1]
  zona_summary_complete$PreĂ§o_sd <- zona_summary_complete$PreĂ§o[, 2]
  zona_summary_complete <- zona_summary_complete[, -3]
  
  write.xlsx(zona_summary_complete,
             file = arquivo_zona,
             rowNames = FALSE)
  
  return(list(geral = overall_summary,
              zona = zona_summary_complete,
              dados_filtrados = Preco))
}

