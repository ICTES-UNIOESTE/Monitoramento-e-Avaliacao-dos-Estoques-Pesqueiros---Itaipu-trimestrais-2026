# FunĂ§Ăµes auxiliares ####

limpa_chave <- function(x){
  x <- as.character(x)
  x <- trimws(x)
  x <- iconv(x, from = "", to = "ASCII//TRANSLIT")
  x <- tolower(x)
  x <- gsub("[^a-z0-9]+", " ", x)
  x <- gsub("\\s+", " ", x)
  trimws(x)
}

pega_coluna <- function(dados, candidatos){
  nomes <- names(dados)
  chave_nomes <- limpa_chave(nomes)
  chave_candidatos <- limpa_chave(candidatos)
  
  for(padrao in chave_candidatos){
    ind <- which(chave_nomes == padrao)
    if(length(ind) > 0) return(nomes[ind[1]])
  }
  
  for(padrao in chave_candidatos){
    ind <- grep(padrao, chave_nomes)
    if(length(ind) > 0) return(nomes[ind[1]])
  }
  
  stop(paste("Coluna nĂŁo encontrada. Procurei por:", paste(candidatos, collapse = ", ")))
}

