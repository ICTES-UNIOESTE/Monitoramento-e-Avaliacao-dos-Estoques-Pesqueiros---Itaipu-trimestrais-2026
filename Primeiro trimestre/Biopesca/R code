plotar_preco <- function(coluna_preco, titulo, arquivo_res, arquivo_montante, cor_montante){
  if(is.na(coluna_preco) || !coluna_preco %in% names(Precos)){
    message("Coluna de preço não encontrada para: ", titulo)
    return(invisible(NULL))
  }
  
  idx <- !is.na(Precos[[coluna_preco]]) & Precos[[coluna_preco]] > 0 & !is.na(Precos$Estoque)
  Preco <- Precos[idx, c("Zona", "Estoque", coluna_preco)]
  colnames(Preco) <- c("Zona", "Pescado", "Preço")
  Preco$Pescado <- padronizar_pescado(Preco$Pescado)
  Preco$Zona <- factor(Preco$Zona, levels = c("Fluvial", "Transição", "Lacustre", "Montante"))
  
  if(nrow(Preco) == 0){
    message("Sem dados para: ", titulo)
    return(invisible(NULL))
  }
  
  # Overall summary data frame
  overall_summary <- aggregate(`Preço` ~ `Pescado`, data = Preco,
                               FUN = function(x) c(mean = mean(x), sd = sd(x)))
  overall_summary$Zona <- "Geral"
  overall_summary <- as.data.frame(overall_summary)
  colnames(overall_summary) <- c("Pescado", "Preço", "Zona")
  
  # Zona-specific summary data frame
  zona_summary <- aggregate(Preço ~ Pescado + Zona, data = Preco,
                            FUN = function(x) c(mean = mean(x), sd = sd(x)))
  
  zona_summary1 <- aggregate(Preço ~ Pescado + Zona, data = Preco,
                             FUN = function(x) c(mean = mean(x)))
  print(mean(zona_summary1[, 3], na.rm = TRUE))
  # Média geral por zona, mantida apenas para conferência no console
  print(aggregate(as.numeric(zona_summary1[, 3]) ~ Zona, data = zona_summary1, FUN = mean, na.rm = TRUE))
  
  zona_summary <- zona_summary %>% arrange(Pescado)
  
  complete_set <- expand.grid(Pescado = unique(zona_summary$Pescado),
                              Zona = c("Fluvial", "Transição", "Lacustre", "Montante"))
  
  zona_summary_complete <- merge(zona_summary, complete_set, by = c("Pescado", "Zona"), all = TRUE)
  zona_summary_complete$Zona <- factor(zona_summary_complete$Zona, levels = c("Fluvial", "Transição", "Lacustre", "Montante"))
  zona_summary_complete <- zona_summary_complete %>% arrange(Pescado, Zona)
  colnames(zona_summary_complete) <- c("Pescado", "Zona", "Preço")
  
  combined_data <- bind_rows(zona_summary_complete, overall_summary)
  combined_data$Zona <- factor(combined_data$Zona, levels = c("Geral", "Fluvial", "Transição", "Lacustre", "Montante"))
  
  zona_summary_res <- zona_summary_complete[zona_summary_complete$Zona != "Montante", ]
  zona_summary_montante <- zona_summary_complete[zona_summary_complete$Zona == "Montante", ]
  
  p1 <- ggplot(zona_summary_res, aes(x = Pescado, y = zona_summary_res[, 3][, 1], fill = Zona)) +
    geom_bar(stat = "identity", position = "dodge") +
    geom_errorbar(aes(ymin = zona_summary_res[, 3][, 1],
                      ymax = zona_summary_res[, 3][, 1] + zona_summary_res[, 3][, 2]),
                  width = 0,
                  position = position_dodge(0.9)) +
    scale_fill_manual(values = c("#045e9a", "#da2420", "#009241")) +
    coord_flip() +
    theme_minimal() +
    labs(
      title = titulo,
      x = "",
      y = "Preço em reais (média e desvio-padrão)",
      fill = "Zona"
    )
  print(p1)
  ggsave(arquivo_res, plot = p1, width = 20, height = 15, units = "cm", dpi = 300)
  
  zona_summary_montante <- zona_summary_montante %>%
    mutate(
      Preço.mean = Preço[, 1],
      Preço.sd   = Preço[, 2]
    )
  
  zona_summary_montante_clean <- zona_summary_montante %>%
    filter(!is.na(Preço.mean))
  
  if(nrow(zona_summary_montante_clean) > 0){
    p2 <- ggplot(zona_summary_montante_clean, aes(x = Pescado, y = Preço.mean, fill = Zona)) +
      geom_bar(stat = "identity", position = "dodge") +
      geom_errorbar(aes(ymin = zona_summary_montante_clean[, 3][, 1],
                        ymax = zona_summary_montante_clean[, 3][, 1] + zona_summary_montante_clean[, 3][, 2]),
                    width = 0,
                    position = position_dodge(0.9)) +
      scale_fill_manual(values = c(cor_montante)) +
      coord_flip() +
      theme_minimal() +
      labs(
        title = titulo,
        x = "",
        y = "Preço em reais (média e desvio-padrão)",
        fill = "Zona"
      )
    print(p2)
    ggsave(arquivo_montante, plot = p2, width = 18, height = 10, units = "cm", dpi = 300)
  }
  
  write.xlsx(zona_summary_complete, paste0(gsub(".jpeg", "", arquivo_res, fixed = TRUE), ".xlsx"), rowNames = FALSE)
  invisible(zona_summary_complete)
}

