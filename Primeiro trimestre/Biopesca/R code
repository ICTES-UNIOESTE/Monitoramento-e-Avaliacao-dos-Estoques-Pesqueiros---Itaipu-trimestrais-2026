  aliMat <- as.matrix(aliM)
  colnames(aliMat) <- "Montante"
  # Plot
  jpeg(filename = "Alimentacao (Montante).jpeg",
       width = 12, height = 9, units = "cm", pointsize = 12,
       quality = 100, res = 300)
  par(mfrow = c(1, 1), mar = c(4, 6, 1, 1), oma = c(0, 0, 0, 0))
  # Cores para os graus de repleção
  cor_montante <- rep("grey", nrow(aliMat))
  # Gráfico
  x1 <- barplot(aliMat,
                beside = TRUE,
                horiz = TRUE,
                yaxt = "n",
                col = cor_montante,
                xlab = "Frequência (Número de indivíduos)",
                xlim = c(0, max(aliMat) * 1.3))
  # Eixo Y com os graus de repleção
  axis(side = 2, at = x1, labels = rownames(aliMat), cex.axis = 0.9, las = 2)
  # Título
  mtext("Grau de Repleção ", side = 2, line = 4, cex = 1.2)
  mtext("Montante", side = 2, line = 2, cex = 1.2)
  dev.off()
