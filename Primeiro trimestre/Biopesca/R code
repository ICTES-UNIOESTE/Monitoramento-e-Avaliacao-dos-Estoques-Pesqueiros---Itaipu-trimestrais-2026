      count <- maturidade[!is.na(maturidade) & maturidade != "IMT"]
      
      TabParametros[i, 12] <- (length(count) / length(maturidade2)) * 100
      
      TabParametros[i, 16] <- sum(maturidade == "IMT", na.rm = TRUE)
      
      TabParametros[i, 17] <- sum(maturidade != "IMT", na.rm = TRUE)
      
      ok <- complete.cases(x, y) & x > 0 & y > 0
      if(sum(ok) > 20){
        WT_LT <- lm(log10(y[ok]) ~ log10(x[ok]))
        TabParametros[i, 5] <- round(10^WT_LT$coefficients[1], 4)
        TabParametros[i, 6] <- round(WT_LT$coefficients[2], 4)
        Resumo = summary(WT_LT)
        EP = Resumo$coefficients[2, 2]
        parametros = cbind(Resumo$coefficients[, 1], confint(WT_LT))
        TabParametros[i, 7] <- parametros[2, 2]
        TabParametros[i, 8] <- parametros[2, 3]
      }
      
    }, error = function(e) {
      cat("Error occurred for species:", Comp[i], "\n")
      TabParametros[i, ] <- NA
    })
  }
  
  TabParametros[is.nan(TabParametros) | is.infinite(TabParametros)] <- NA
  
  TabParametros <- as.data.frame(TabParametros)
  
  TabParametros$Espécie <- rownames(TabParametros)
  
  # Reorder the columns with "Espécie" as the first column
  TabParametros <- TabParametros[, c("Espécie", names(TabParametros)[names(TabParametros) != "Espécie"])]
  
  TabParametros <- as.data.frame(TabParametros)
  
  write.xlsx(TabParametros, "Parametros especies (montante).xlsx")
  
  Zones <- unique(BioJuAg23_montante$Zona)
  TabParametros2 <- expand.grid(Espécie = Spp, Zona = Zones)
  TabParametros2$CP <- NA  # Initialize CP_medio with NA
  
  # Calculate the mean CP for each species and zone
  mean_CP <- aggregate(CP ~ Espécie + Zona, data = BioJuAg23_montante, FUN = mean, na.rm = TRUE)
  mean_CP
  
  # Merge the calculated mean CP with the TabParametros2 data frame
  TabParametros2 <- merge(TabParametros2, mean_CP, by = c("Espécie", "Zona"), all.x = TRUE)
  mean(TabParametros2[, 4], na.rm = TRUE)
  mean_CP_by_zone <- aggregate(CP.y ~ Zona, data = TabParametros2, FUN = mean, na.rm = TRUE)
  
  TabParametros2 <- as.data.frame(TabParametros2)
  TabParametros2$Espécie <- rownames(TabParametros2)
  
  # Reorder the columns with "Espécie" as the first column
  TabParametros2 <- TabParametros2[, c("Espécie", names(TabParametros2)[names(TabParametros2) != "Espécie"])]
  
  TabParametros2 <- as.data.frame(TabParametros2)
  
  TabParametros2 <- TabParametros2[, -3]
  
  colnames(TabParametros2) <- c("Espécie", "Zona", "CP médio")
  
  # Add row names as a column named "Espécie"
  TabParametros2$Espécie <- rownames(TabParametros2)
  
  # Reprodução #####
  # Reprodução — somente Montante ####
  ordem_estagio_m <- c("IMT", "MAT", "RPD", "ESG", "REG")
  ordem_estagio_m <- c(ordem_estagio_m[ordem_estagio_m %in% unique(BioJuAg23_montante$Estagio)],
                       sort(setdiff(unique(na.omit(BioJuAg23_montante$Estagio)), ordem_estagio_m)))
  repM <- table(factor(BioJuAg23_montante$Estagio, levels = ordem_estagio_m))
  repM <- repM[!is.na(names(repM))]
  # Converte para matriz 1 coluna (necessário para barplot com beside=TRUE)
  repMat <- as.matrix(repM)
  colnames(repMat) <- "Montante"
  # Plot
  jpeg(filename = "Reprodução (Montante).jpeg",
       width = 12, height = 9, units = "cm", pointsize = 12,
       quality = 100, res = 300)
  
  par(mfrow = c(1, 1), mar = c(4, 6, 1, 1), oma = c(0, 0, 0, 0))
  
  # Cores para os 5 estágios
  cor_montante <- rep("gray", nrow(repMat))
  # Gráfico de barras
  x1 <- barplot(repMat,
                beside = TRUE,
                horiz = TRUE,
                yaxt = "n",
                col = cor_montante,
                xlab = "Frequência (Número de indivíduos)",
                xlim = c(0, ceiling(max(repMat) * 1.15)))
  # Eixo y (estágios)
  axis(side = 2, at = x1, labels = rownames(repMat), cex.axis = 0.9, las = 2)
  # Título lateral opcional
  mtext("Montante", side = 2, line = 3.5, cex = 1.25)
  dev.off()
  
  # Alimentação — somente Montante ####
  graus_replecao_m <- sort(unique(na.omit(BioJuAg23_montante$GR)))
  aliM <- table(factor(BioJuAg23_montante$GR, levels = graus_replecao_m))
