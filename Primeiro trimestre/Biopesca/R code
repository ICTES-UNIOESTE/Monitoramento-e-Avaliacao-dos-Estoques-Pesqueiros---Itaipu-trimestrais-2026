achar_coluna <- function(dados, padrao){
  nms <- names(dados)
  nms2 <- iconv(nms, from = "UTF-8", to = "ASCII//TRANSLIT")
  nms2 <- tolower(nms2)
  out <- grep(padrao, nms2)
  if(length(out) == 0) return(NA)
  nms[out[1]]
}

padronizar_pescado <- function(x){
  x <- trimws(as.character(x))
  x2 <- iconv(tolower(x), from = "UTF-8", to = "ASCII//TRANSLIT")
  x2 <- trimws(x2)
  x[x2 %in% c("perna de moca", "perna-de-moca", "perna de moça", "perna-de-moça")] <- "Perna-de-moça"
  x[x2 %in% c("luz baixa", "luz-baixa")] <- "Luz-baixa"
  x[x2 %in% c("dourado cachorro", "dourado-cachorro")] <- "Dourado-cachorro"
  x[x2 %in% c("tucunare", "tucunaré")] <- "Tucunaré"
  x[x2 %in% c("traira", "traíra")] <- "Traíra"
  x[x2 %in% c("corvina", "curvina")] <- "Corvina"
  x[x2 %in% c("piapara") ] <- "Piapara"
  x[x2 %in% c("piauçu", "piaucu") ] <- "Piauçu"
  x[x2 %in% c("cara", "cará") ] <- "Cará"
  x[x2 %in% c("tilapia", "tilápia") ] <- "Tilápia"
  x[x2 %in% c("bagre africano") ] <- "Bagre Africano"
  x
}

