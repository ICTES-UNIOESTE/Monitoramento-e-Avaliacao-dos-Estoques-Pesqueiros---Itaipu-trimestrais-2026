library(readxl)
library(dplyr)
library(openxlsx)

# Leitura da aba de preços ####
BioPreco <- data.frame(
  read_xlsx("Biopesca_2026_ TRIMESTRAL_-M-A-M.xlsx", sheet = "Preços"),
  check.names = FALSE
)

# Remove espaços extras dos nomes das colunas, principalmente "Zona "
names(BioPreco) <- trimws(names(BioPreco))

# Padroniza nomes das colunas para facilitar o restante do código
BioPreco <- BioPreco %>%
  rename(
    Zona = `Zona`,
    Codigo.Pescador = `Código/Pescador`,
    Pescado = `Estoque`,
    Tamanho.peixe = `Tamanho do peixe`,
    Preco.Inteiro.Particular = `Inteiro (Particular)`,
    Preco.Inteiro.Peixeiro = `Inteiro (Peixeiro)`,
    Preco.File.Particular = `Filé (Particular)`,
    Preco.File.Peixeiro = `Filé (Peixeiro)`
  )

# Padronização básica dos textos
BioPreco$Zona <- trimws(as.character(BioPreco$Zona))
BioPreco$Pescado <- trimws(as.character(BioPreco$Pescado))
BioPreco$Tamanho.peixe <- trimws(as.character(BioPreco$Tamanho.peixe))

# Converte preços para numérico, caso algum valor venha com vírgula decimal
converter_preco <- function(x) {
  as.numeric(gsub(",", ".", as.character(x)))
}

BioPreco$Preco.Inteiro.Particular <- converter_preco(BioPreco$Preco.Inteiro.Particular)
BioPreco$Preco.Inteiro.Peixeiro    <- converter_preco(BioPreco$Preco.Inteiro.Peixeiro)
BioPreco$Preco.File.Particular     <- converter_preco(BioPreco$Preco.File.Particular)
BioPreco$Preco.File.Peixeiro       <- converter_preco(BioPreco$Preco.File.Peixeiro)

# Remove eventuais linhas sem pescado ou com "outros"
# No arquivo de preços, a coluna Estoque já está no nome comercial, então não é necessário
# fazer a substituição espécie científica -> pescado usada nos códigos antigos.
BioPreco <- BioPreco %>%
  filter(!is.na(Pescado), Pescado != "") %>%
  filter(tolower(trimws(Pescado)) != "outros")

# Ordem das zonas igual à usada nos relatórios anteriores
zonas_padrao <- c("Fluvial", "Transição", "Lacustre", "Montante")

# Função para gerar as tabelas de preço geral e por zona ####
processar_preco <- function(dados, coluna_preco, arquivo_geral, arquivo_zona) {
  
  Preco <- dados[, c("Zona", "Pescado", coluna_preco)]
  colnames(Preco) <- c("Zona", "Espécie", "Preço")
  
  Preco <- Preco[!is.na(Preco$Preço) & Preco$Preço > 0, ]
  Preco <- Preco[!is.na(Preco$Espécie) & trimws(Preco$Espécie) != "", ]
  Preco <- Preco[tolower(trimws(Preco$Espécie)) != "outros", ]
  
  # Mantém as inspeções do código antigo
  print(tapply(Preco$Preço, interaction(Preco$Zona, Preco$Espécie), mean, na.rm = TRUE))
  print(tapply(Preco$Preço, interaction(Preco$Zona, Preco$Espécie), sd, na.rm = TRUE))
  
  # Resumo geral
  overall_summary <- aggregate(
    Preço ~ Espécie,
    data = Preco,
    FUN = function(x) c(mean = mean(x, na.rm = TRUE), sd = sd(x, na.rm = TRUE))
  )
  
  overall_summary$Zona <- "Geral"
  overall_summary <- as.data.frame(overall_summary)
  colnames(overall_summary) <- c("Espécies", "Preço", "Zona")
  
  overall_summary$Preço_mean <- overall_summary$Preço[, 1]
  overall_summary$Preço_sd <- overall_summary$Preço[, 2]
  overall_summary <- overall_summary[, -2]
  
  overall_summary <- overall_summary %>%
    arrange(Espécies)
  
  write.xlsx(overall_summary, file = arquivo_geral)
  
  # Resumo por zona
  zona_summary <- aggregate(
    Preço ~ Espécie + Zona,
    data = Preco,
    FUN = function(x) c(mean = mean(x, na.rm = TRUE), sd = sd(x, na.rm = TRUE))
  )
  
  zona_summary <- zona_summary %>%
    arrange(Espécie)
  
  # Conjunto completo de pescado x zona, para manter linhas com NA quando não houver registro
  complete_set <- expand.grid(
    Espécie = unique(zona_summary$Espécie),
    Zona = zonas_padrao
  )
  
  zona_summary_complete <- merge(
    zona_summary,
    complete_set,
    by = c("Espécie", "Zona"),
    all = TRUE
  )
  
  zona_summary_complete$Zona <- factor(
    zona_summary_complete$Zona,
    levels = zonas_padrao
  )
  
  zona_summary_complete <- zona_summary_complete %>%
    arrange(Espécie, Zona)
  
  colnames(zona_summary_complete) <- c("Espécies", "Zona", "Preço")
  
  zona_summary_complete$Preço_mean <- zona_summary_complete$Preço[, 1]
  zona_summary_complete$Preço_sd <- zona_summary_complete$Preço[, 2]
  zona_summary_complete <- zona_summary_complete[, -3]
  
  write.xlsx(zona_summary_complete, file = arquivo_zona)
  
  return(list(
    geral = overall_summary,
    por_zona = zona_summary_complete
  ))
}

