# OPCIONAL: tabelas separando também por tamanho do peixe ####
# Use somente se quiser manter Pequeno/Grande separado em vez de calcular a média
# por pescado agregando todos os tamanhos.

processar_preco_por_tamanho <- function(dados, coluna_preco, arquivo_geral, arquivo_zona) {
  
  Preco <- dados[, c("Zona", "Pescado", "Tamanho.peixe", coluna_preco)]
  colnames(Preco) <- c("Zona", "Espécie", "Tamanho", "Preço")
  
  Preco <- Preco[!is.na(Preco$Preço) & Preco$Preço > 0, ]
  Preco <- Preco[!is.na(Preco$Espécie) & trimws(Preco$Espécie) != "", ]
  Preco <- Preco[tolower(trimws(Preco$Espécie)) != "outros", ]
  Preco$Tamanho[is.na(Preco$Tamanho) | Preco$Tamanho == ""] <- "Não informado"
  
  overall_summary <- aggregate(
    Preço ~ Espécie + Tamanho,
    data = Preco,
    FUN = function(x) c(mean = mean(x, na.rm = TRUE), sd = sd(x, na.rm = TRUE))
  )
  
  overall_summary$Zona <- "Geral"
  overall_summary <- as.data.frame(overall_summary)
  colnames(overall_summary) <- c("Espécies", "Tamanho", "Preço", "Zona")
  overall_summary$Preço_mean <- overall_summary$Preço[, 1]
  overall_summary$Preço_sd <- overall_summary$Preço[, 2]
  overall_summary <- overall_summary[, -3]
  overall_summary <- overall_summary %>% arrange(Espécies, Tamanho)
  write.xlsx(overall_summary, file = arquivo_geral)
  
  zona_summary <- aggregate(
    Preço ~ Espécie + Tamanho + Zona,
    data = Preco,
    FUN = function(x) c(mean = mean(x, na.rm = TRUE), sd = sd(x, na.rm = TRUE))
  )
  
  complete_set <- expand.grid(
    Espécie = unique(zona_summary$Espécie),
    Tamanho = unique(zona_summary$Tamanho),
    Zona = zonas_padrao
  )
  
  zona_summary_complete <- merge(
    zona_summary,
    complete_set,
    by = c("Espécie", "Tamanho", "Zona"),
    all = TRUE
  )
  
  zona_summary_complete$Zona <- factor(zona_summary_complete$Zona, levels = zonas_padrao)
  zona_summary_complete <- zona_summary_complete %>% arrange(Espécie, Tamanho, Zona)
  
  colnames(zona_summary_complete) <- c("Espécies", "Tamanho", "Zona", "Preço")
  zona_summary_complete$Preço_mean <- zona_summary_complete$Preço[, 1]
  zona_summary_complete$Preço_sd <- zona_summary_complete$Preço[, 2]
  zona_summary_complete <- zona_summary_complete[, -4]
  
  write.xlsx(zona_summary_complete, file = arquivo_zona)
  
  return(list(
    geral = overall_summary,
    por_zona = zona_summary_complete
  ))
}

